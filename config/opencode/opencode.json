{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "echo *": "allow",
          "fd *": "allow",
          "find *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "rg *": "allow",
          "tail *": "allow"
        }
      }
    }
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "instructions": ["AGENTS.md", ".github/copilot-instructions.md"],
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "github": {
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_KEY}"
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  },
  "plugin": ["opencode-gemini-auth@latest"],
  "provider": {
    "anthropic": {
      "options": {
        "setCacheKey": true
      }
    },
    "openai": {
      "options": {
        "setCacheKey": true
      }
    }
  }
}
