{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "echo *": "allow",
          "fd *": "allow",
          "find *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "rg *": "allow",
          "tail *": "allow"
        }
      }
    }
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md"
  ],
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "github": {
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_KEY}"
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  },
  "model": "ollama/gemma4:26b",
  "plugin": [
    "opencode-gemini-auth@latest"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "setCacheKey": true
      }
    },
    "ollama": {
      "models": {
        "gemma4:26b": {
          "_launch": true,
          "name": "gemma4:26b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "openai": {
      "options": {
        "setCacheKey": true
      }
    }
  }
}