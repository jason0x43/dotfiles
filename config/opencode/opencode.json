{
  "$schema": "https://opencode.ai/config.json",

  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "echo *": "allow",
          "find *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "fd *": "allow",
          "head *": "allow",
          "tail *": "allow"
        }
      }
    }
  },

  "experimental": {
    "disable_paste_summary": true
  },

  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md"
  ],

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    // "graphiti": {
    //   "type": "remote",
    //   "url": "http://localhost:48000/mcp",
    //   "enabled": true
    // },
    "github": {
      "type": "remote",
      "enabled": false,
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_KEY}"
      }
    }
  },

  "plugin": [
    "opencode-gemini-auth@latest"
  ]
}
