#!/usr/bin/env python3
"""Update local environment and toolchain resources."""

import argparse
import json
import os
import pwd
import re
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, List, Optional, Sequence, Union, Callable, Literal, Any


@dataclass(frozen=True)
class Module:
    """An install or update task for a specific tool or resource"""

    name: str
    fn: Callable[[], None]


@dataclass(frozen=True)
class Colors:
    """Terminal color output helper"""

    green: str
    blue: str
    red: str
    yellow: str
    reset: str

    @staticmethod
    def from_tty(is_tty: bool) -> "Colors":
        if not is_tty:
            return Colors("", "", "", "", "")
        return Colors(
            green="\033[1;32m",
            blue="\033[1;34m",
            red="\033[1;31m",
            yellow="\033[1;33m",
            reset="\033[0m",
        )


IS_LINUX: bool = sys.platform.startswith("linux")
IS_MACOS: bool = sys.platform == "darwin"
COLORS = Colors.from_tty(sys.stdout.isatty())
HOME = Path.home()
DOTFILES = Path(os.environ.get("DOTFILES", str(HOME / ".dotfiles"))).expanduser()
XDG_CACHE_HOME = Path(
    os.environ.get("XDG_CACHE_HOME", str(HOME / ".cache"))
).expanduser()
XDG_CONFIG_HOME = Path(
    os.environ.get("XDG_CONFIG_HOME", str(HOME / ".config"))
).expanduser()
XDG_DATA_HOME = Path(
    os.environ.get("XDG_DATA_HOME", str(HOME / ".local" / "share"))
).expanduser()
XDG_RUNTIME_DIR = Path(
    os.environ.get("XDG_RUNTIME_DIR", os.environ.get("TMPDIR", "/tmp"))
).expanduser()
HOMEBREW_BASE = (
    Path("/home/linuxbrew/.linuxbrew") if IS_LINUX else Path("/opt/homebrew")
)
BREW = HOMEBREW_BASE / "bin" / "brew"
MODULES: list[Module] = []


def register_module(
    name: str,
    *,
    os: Optional[Literal["linux", "macos"]] = None,
    priority: Optional[int] = None,
) -> Callable[[Callable[[], None]], Callable[[], None]]:
    """Register an install/update module.

    The order that modules are registered is significant.
    """

    def decorator(fn: Callable[[], None]) -> Callable[[], None]:
        if any(m.name == name for m in MODULES):
            raise ValueError(f"Duplicate module: {name}")
        if not os or os == "linux" and IS_LINUX or os == "macos" and IS_MACOS:
            MODULES.append(Module(name, fn))

        return fn

    return decorator


os.environ["DOTFILES"] = str(DOTFILES)
os.environ["XDG_CACHE_HOME"] = str(XDG_CACHE_HOME)
os.environ["XDG_CONFIG_HOME"] = str(XDG_CONFIG_HOME)
os.environ["XDG_DATA_HOME"] = str(XDG_DATA_HOME)
os.environ["XDG_RUNTIME_DIR"] = str(XDG_RUNTIME_DIR)
os.environ["HOMEBREW_AUTO_UPDATE_SECS"] = "300"
os.environ["HOMEBREW_BASE"] = str(HOMEBREW_BASE)
os.environ["PATH"] = f"{HOMEBREW_BASE / 'bin'}:{os.environ.get('PATH', '')}"

install_missing: bool = False


def log(message: str, color: Optional[str] = None) -> None:
    """Print a primary message to stdout"""
    tint = color if color is not None else COLORS.green
    print(f"{tint}>>>{COLORS.reset} {message}")


def log_sub(message: str) -> None:
    """Print a secondary message to stdout"""
    log(message, COLORS.blue)


def warn(message: str) -> None:
    """Print a warning to stdout"""
    log(message, COLORS.yellow)


def err(message: str) -> None:
    """Print an error to stdout"""
    log(message, COLORS.red)


def command_exists(command: str) -> bool:
    """Return true if a command exists on the system"""
    return shutil.which(command) is not None


def owner(path: Path) -> str:
    """Return the owner of a file"""
    try:
        uid = path.stat().st_uid
        return pwd.getpwuid(uid).pw_name
    except (FileNotFoundError, KeyError):
        return ""


def makedir(path: Path) -> None:
    """Create a directory and any parents"""
    if path.is_dir():
        return
    path.mkdir(parents=True, exist_ok=True)
    log_sub(f"Created {path}/")


def link(source: Path, target: Path) -> None:
    """Create a symlink"""
    if target.exists() or target.is_symlink():
        return
    target.parent.mkdir(parents=True, exist_ok=True)
    target.symlink_to(source)
    log_sub(f"Linked {source} -> {target}")


def sync_link(source: Path, target: Path) -> None:
    """Create or update a symlink"""
    if not source.exists():
        warn(f"Missing source for link: {source}")
        return

    if target.is_symlink():
        current = (target.parent / target.readlink()).resolve()
        desired = source.resolve()
        if current == desired:
            return
        target.unlink()
        log_sub(f"Removed {target}")
    elif target.exists():
        warn(f"Skipping existing non-link: {target}")
        return

    target.parent.mkdir(parents=True, exist_ok=True)
    target.symlink_to(source)
    log_sub(f"Linked {source} -> {target}")


def run_command(
    command: Union[str, Sequence[str]],
    *,
    capture_output: bool = False,
    quiet: bool = False,
    shell: bool = False,
    extra_env: Optional[Dict[str, str]] = None,
) -> subprocess.CompletedProcess[str]:
    """Run a command and return the result"""
    env = os.environ.copy()
    if extra_env:
        env.update(extra_env)

    kwargs: dict[str, Any] = {}

    if capture_output:
        kwargs["stdout"] = subprocess.PIPE
        kwargs["stderr"] = subprocess.PIPE
    elif quiet:
        kwargs["stdout"] = subprocess.DEVNULL
        kwargs["stderr"] = subprocess.DEVNULL

    if shell:
        kwargs["executable"] = "/bin/bash"

    return subprocess.run(command, text=True, env=env, shell=shell, **kwargs)


def brew_install(pkg: str) -> bool:
    if not BREW.exists():
        print(f"Unable to install {pkg}")

    log(f"Installing {pkg}...")
    result = run_command([str(BREW), "install", "-q", pkg])
    return result.returncode == 0


def sync_git_repo(repo: str, destination: Path) -> None:
    """Clone a repo if missing, otherwise update it"""
    url = f"https://github.com/{repo}.git"

    if (destination / ".git").is_dir():
        log_sub(f"Updating {repo}...")
        result = run_command(["git", "-C", str(destination), "pull", "--ff-only"])
        if result.returncode != 0:
            warn(f"Unable to update {repo}")
        return

    if destination.exists():
        warn(f"Skipping existing non-git directory: {destination}")
        return

    destination.parent.mkdir(parents=True, exist_ok=True)
    log_sub(f"Cloning {repo}...")
    result = run_command(["git", "clone", url, str(destination)])
    if result.returncode != 0:
        warn(f"Unable to clone {repo}")


def resolve_agent_skill_path(repo_dir: Path, skill: str, path: Optional[str] = None) -> Optional[Path]:
    """Resolve a skill directory from a repo"""
    base_dir = repo_dir / path if path else repo_dir
    candidate = base_dir / skill
    if candidate.is_dir():
        return candidate
    return None


def ensure_skill_frontmatter_name(skill_dir: Path) -> None:
    """Ensure a skill's frontmatter name matches its directory name."""
    skill_file = skill_dir / "SKILL.md"
    if not skill_file.is_file():
        warn(f"Missing SKILL.md in {skill_dir}")
        return

    try:
        content = skill_file.read_text(encoding="utf-8")
    except OSError as exc:
        warn(f"Unable to read {skill_file}: {exc}")
        return

    frontmatter_match = re.match(r"^(---\n)(.*?)(\n---\n?)", content, re.DOTALL)
    if not frontmatter_match:
        warn(f"Missing frontmatter in {skill_file}")
        return

    opening, frontmatter, closing = frontmatter_match.groups()
    expected_name = skill_dir.name
    name_pattern = re.compile(r'(?m)^name:\s*(?:["\']?)([^"\'\n]+)(?:["\']?)\s*$')
    name_match = name_pattern.search(frontmatter)

    if name_match and name_match.group(1).strip() == expected_name:
        return

    if name_match:
        updated_frontmatter = name_pattern.sub(f"name: {expected_name}", frontmatter, count=1)
    else:
        updated_frontmatter = f"name: {expected_name}\n{frontmatter}" if frontmatter else f"name: {expected_name}"

    updated_content = (
        content[: frontmatter_match.start()]
        + opening
        + updated_frontmatter
        + closing
        + content[frontmatter_match.end() :]
    )

    if updated_content == content:
        return

    try:
        skill_file.write_text(updated_content, encoding="utf-8")
    except OSError as exc:
        warn(f"Unable to update {skill_file}: {exc}")
        return

    log_sub(f"Patched skill name in {skill_file}")


@register_module("home")
def module_home() -> None:
    """Setup the home directory"""

    log("Updating home directory files...")

    # Remove broken dotfile symlinks from ~/
    for entry in HOME.iterdir():
        if not entry.name.startswith("."):
            continue
        if entry.is_symlink() and not entry.exists():
            entry.unlink(missing_ok=True)
            log_sub(f"Removed {entry}")

    # Remove broken symlinks from ~/.config
    if XDG_CONFIG_HOME.is_dir():
        for entry in XDG_CONFIG_HOME.iterdir():
            if entry.is_symlink() and not entry.exists():
                entry.unlink(missing_ok=True)
                log_sub(f"Removed {entry}")

    # Link files in .dotfiles/home into ~/
    home_dir = DOTFILES / "home"
    if home_dir.exists():
        for source in sorted(home_dir.iterdir()):
            link(source, HOME / f".{source.name}")

    makedir(XDG_CONFIG_HOME)

    config_dir = DOTFILES / "config"
    if config_dir.exists():
        for source in sorted(config_dir.iterdir()):
            target = XDG_CONFIG_HOME / source.name
            if target.is_dir() and not target.is_symlink():
                local_dir = XDG_CONFIG_HOME / "local"
                local_dir.mkdir(parents=True, exist_ok=True)
                destination = local_dir / source.name
                try:
                    shutil.move(str(target), str(destination))
                    log_sub(f"Moved {target} -> {destination}")
                except shutil.Error as exc:
                    warn(f"Unable to move {target}: {exc}")
            link(source, target)

    makedir(XDG_CACHE_HOME / "zsh")


@register_module("apt", os="linux")
def module_apt() -> None:
    """Update app packages"""
    log("Upgrading apt packages...")
    run_command(["sudo", "apt", "update", "-qq"])
    run_command(["sudo", "apt", "upgrade", "-qq"])


@register_module("brew")
def module_brew() -> None:
    log("Setting up homebrew...")
    if not BREW.exists():
        if not install_missing:
            warn("Homebrew not installed")
            return

        log_sub("Installing Homebrew...")
        run_command(
            'NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"',
            shell=True,
        )

    brew_packages = [
        "bat",
        "eza",
        "fd",
        "ripgrep",
        "zoxide",
        "mise",
        "lazygit",
        "neovim",
    ]

    if IS_MACOS:
        brew_packages.append("1password-cli")

    log_sub("Installing/updating core packages...")
    run_command(
        [str(BREW), "install", "-q", *brew_packages],
        extra_env={
            "HOMEBREW_NO_UPDATE_REPORT_NEW": "true",
            "HOMEBREW_NO_INSTALL_UPGRADE": "true",
        },
    )

    log_sub("Updating installed brew packages...")
    run_command(
        [str(BREW), "upgrade", "-q"],
        extra_env={
            "HOMEBREW_NO_UPDATE_REPORT_NEW": "true",
            "HOMEBREW_NO_INSTALL_UPGRADE": "true",
        },
    )

    git_completion = HOMEBREW_BASE / "share" / "zsh" / "site-functions" / "_git"
    if git_completion.exists():
        log_sub("Removing default git zsh completions...")
        if owner(HOMEBREW_BASE) == os.environ.get("USER", ""):
            git_completion.unlink(missing_ok=True)
        else:
            run_command(["sudo", "rm", "-f", str(git_completion)])


@register_module("uv")
def module_uv() -> None:
    if not command_exists("uv"):
        log("Installing uv...")
        run_command(
            "curl -LsSf https://astral.sh/uv/install.sh | env UV_NO_MODIFY_PATH=1 sh",
            shell=True,
        )

    log("Updating uv...")
    run_command(["uv", "self", "update"])

    log("Updating uv tools...")
    run_command(["uv", "tool", "upgrade", "--all"])


@register_module("bat")
def module_bat() -> None:
    """Install and configure bat"""
    if not command_exists("bat") and not brew_install("bat"):
        return

    log("Rebuilding bat cache...")
    result = run_command(["bat", "cache", "--build"], capture_output=True)
    if result.returncode != 0:
        err("Error rebuilding bat cache")
        if result.stderr.strip():
            err(result.stderr.strip())
        elif result.stdout.strip():
            err(result.stdout.strip())


@register_module("fish")
def module_fish() -> None:
    """Install and configure the fish shell"""
    if not command_exists("fish") and not brew_install("fish"):
        return

    log("Updating fish config...")
    run_command(["fish", "-c", "configure"], extra_env={"UV_VENV_CLEAR": "1"})


@register_module("node")
def module_node() -> None:
    def npm_outdated_global_packages() -> List[str]:
        result = run_command(["npm", "outdated", "-g", "--json"], capture_output=True)
        if not result.stdout.strip():
            return []
        try:
            data = json.loads(result.stdout)
        except json.JSONDecodeError:
            warn("Unable to parse npm outdated output")
            return []
        if not isinstance(data, dict):
            return []
        return sorted(data.keys())

    if not command_exists("node") and not brew_install("node"):
        return

    log_sub("Updating global node packages...")
    outdated = npm_outdated_global_packages()
    if not outdated:
        log_sub("No global packages to update")
        return

    for package in outdated:
        log_sub(f"Updating {package}...")
        run_command(["npm", "i", "-g", f"{package}@latest"], quiet=True)


@register_module("pnpm")
def module_pnpm() -> None:
    if not command_exists("pnpm"):
        log("Installing pnpm...")
        run_command("curl -fsSL https://get.pnpm.io/install.sh | sh -", shell=True)

    log_sub("Updating pnpm...")
    run_command(["pnpm", "self-update", "-q"], quiet=True)


@register_module("bun")
def module_bun() -> None:
    if not command_exists("bun"):
        log("Installing bun...")
        run_command("curl -fsSL https://bun.com/install | bash", shell=True)
    else:
        log("Updating bun...")
        run_command(["bun", "upgrade"])

    log("Updating global dependencies...")
    run_command(["bun", "update", "-g", "--latest"])

    log("Updating bun completions...")
    run_command(["bun", "completions"])


@register_module("launchd", os="macos")
def module_launchd() -> None:
    log("Linking and bootstrapping launchd scripts...")
    launch_agents = HOME / "Library" / "LaunchAgents"
    launch_agents.mkdir(parents=True, exist_ok=True)

    launchd_dir = DOTFILES / "launchd"
    if not launchd_dir.exists():
        return

    for source in sorted(launchd_dir.iterdir()):
        target = launch_agents / source.name
        if target.is_symlink():
            continue
        link(source, target)
        run_command(
            ["launchctl", "bootstrap", f"gui/{os.getuid()}", str(target)],
        )
        log_sub(f"Bootstrapped {source.name}")


@register_module("rust", os="macos")
def module_rust() -> None:
    if not command_exists("rustup"):
        log("Installing rust...")
        run_command(
            "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path",
            shell=True,
        )
        return
    else:
        log("Updating rust...")
        run_command(["rustup", "-q", "update"])


@register_module("copilot")
def module_copilot() -> None:
    """Update copilot cli"""
    if command_exists("copilot"):
        log("Updating copilot...")
        run_command(["copilot", "update"])


@register_module("codex")
def module_codex() -> None:
    """Update codex config"""
    if command_exists("codex"):
        log("Updating codex completions...")
        completion_dir = XDG_CONFIG_HOME / "fish" / "completions"
        completion_dir.mkdir(parents=True, exist_ok=True)
        completion_path = completion_dir / "codex.fish"
        result = run_command(["codex", "completion", "fish"], capture_output=True)

        if result.returncode == 0:
            completion_path.write_text(result.stdout, encoding="utf-8")
        else:
            warn("Unable to update codex completions")


@register_module("claude")
def module_claude() -> None:
    """Update claude"""
    if command_exists("claude"):
        log("Updating claude...")
        run_command(["claude", "update"])


@register_module("hammerspoon", os="macos")
def module_hammerspoon() -> None:
    """Update hammerspoon config file location"""
    if Path("/Applications/Hammerspoon.app").exists():
        log("Updating hammerspoon config location...")
        desired = str(XDG_CONFIG_HOME / "hammerspoon" / "init.lua")
        result = run_command(
            ["defaults", "read", "org.hammerspoon.Hammerspoon", "MJConfigFile"],
            capture_output=True,
        )
        current_value = result.stdout.strip() if result.returncode == 0 else ""
        if current_value != desired:
            run_command(
                [
                    "defaults",
                    "write",
                    "org.hammerspoon.Hammerspoon",
                    "MJConfigFile",
                    desired,
                ],
            )
            log_sub("Updated Hammerspoon config file location")


@register_module("mas", os="macos")
def module_mas() -> None:
    if not command_exists("mas") and not brew_install("mas"):
        return

    log("Upgrading Mac App Store apps...")
    run_command(["mas", "upgrade"])


@register_module("agents")
def module_agents() -> None:
    """Sync agent skills and sources"""
    log("Syncing agents...")

    agents_dir = HOME / ".agents"
    agents_skills_dir = agents_dir / "skills"
    agents_sources_dir = agents_dir / "sources"

    makedir(agents_dir)
    makedir(agents_skills_dir)
    makedir(agents_sources_dir)

    local_skills_dir = DOTFILES / "agents" / "skills"
    if local_skills_dir.is_dir():
        for source in sorted(local_skills_dir.iterdir()):
            if source.is_dir():
                ensure_skill_frontmatter_name(source)
                sync_link(source, agents_skills_dir / source.name)

    sources_path = DOTFILES / "agents" / "sources.json"
    if not sources_path.is_file():
        return

    try:
        sources = json.loads(sources_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        warn(f"Unable to parse {sources_path}")
        return

    if not isinstance(sources, list):
        warn(f"Unexpected sources format in {sources_path}")
        return

    for entry in sources:
        if not isinstance(entry, dict):
            warn(f"Skipping invalid source entry: {entry}")
            continue

        repo = entry.get("repo")
        path = entry.get("path")
        skills = entry.get("skills")
        if not isinstance(repo, str) or path is not None and not isinstance(path, str) or not isinstance(skills, list):
            warn(f"Skipping invalid source entry: {entry}")
            continue

        owner, _, name = repo.partition("/")
        if not owner or not name:
            warn(f"Skipping invalid repo: {repo}")
            continue

        repo_dir = agents_sources_dir / owner / name
        sync_git_repo(repo, repo_dir)

        for skill in skills:
            if not isinstance(skill, str):
                warn(f"Skipping invalid skill entry for {repo}: {skill}")
                continue

            source = resolve_agent_skill_path(repo_dir, skill, path)
            if source is None:
                base_dir = repo_dir / path if path else repo_dir
                warn(f"Missing skill '{skill}' in {base_dir}")
                continue

            ensure_skill_frontmatter_name(source)
            sync_link(source, agents_skills_dir / skill)


parser = argparse.ArgumentParser(
    prog="dotfiles",
    description="Update local environment. All modules are updated by default.",
)
parser.add_argument(
    "-i", "--install", action="store_true", help="Install missing things"
)
parser.add_argument(
    "module",
    nargs="?",
    help="A module to update",
    choices=sorted(m.name for m in MODULES),
)
args = parser.parse_args()

os.chdir(HOME)

install_missing = args.install
exit_code = 0

if args.module:
    handler = next((m for m in MODULES if m.name == args.module), None)
    if handler:
        handler.fn()
    else:
        err(f"Unknown module: {args.module}")
        exit_code = 1
else:
    for m in MODULES:
        m.fn()

log("Done")

raise SystemExit(exit_code)
